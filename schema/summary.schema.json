{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/plexusone/structured-evaluation/schema/summary.schema.json",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "target": {
      "type": "string"
    },
    "phase": {
      "type": "string"
    },
    "teams": {
      "items": {
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "agent_id": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "depends_on": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "tasks": {
            "items": {
              "properties": {
                "id": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                },
                "detail": {
                  "type": "string"
                },
                "duration_ms": {
                  "type": "integer"
                },
                "metadata": {
                  "type": "object"
                }
              },
              "additionalProperties": false,
              "type": "object"
            },
            "type": "array"
          },
          "status": {
            "type": "string"
          }
        },
        "additionalProperties": false,
        "type": "object"
      },
      "type": "array"
    },
    "status": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "generated_by": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "type": "object",
  "title": "Summary Report",
  "description": "Schema for GO/NO-GO summary reports from deterministic checks"
}